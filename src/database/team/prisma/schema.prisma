generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

generator dbml {
  provider            = "prisma-dbml-generator"
  output              = "../dbml"
  outputName          = "schema.dbml"
  projectName         = "Expiry Team"
  projectDatabaseType = "PostgreSQL"
  projectNote         = "ER Diagram"
}

datasource db {
  provider = "postgresql"
}

enum DocumentStatuses {
  PROCESSING
  ACTIVE
  ARCHIVED
  FAILED
}

model Document {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  status    DocumentStatuses
  tags      String[]
  name      String           @unique
  key       String           @unique
  fileSize  Float            @map("file_size")
  mimeType  String           @map("mime_type")
  url       String
  expiredAt DateTime         @map("expired_at")
  width     Float?
  height    Float?

  documentExtractedFields DocumentExtractedField[]
  documentDeadlines       DocumentDeadline[]
  actionLogs              ActionLog[]

  @@map("documents")
}

enum ExtractedFieldType {
  EXPIRY_DATE
  ISSUE_DATE
  COUNTERPARTY
  AMOUNT
}

enum ExtractedFieldSource {
  OCR
  REGEX
  MANUAL
}

model DocumentExtractedField {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  type       ExtractedFieldType
  value      String
  confidence Float
  source     ExtractedFieldSource

  documentId String   @map("document_id")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_extracted_fields")
}

enum DeadlineStatus {
  ACTIVE
  COMPLETED
  OVERDUE
}

model DocumentDeadline {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  name      String
  dueAt     DateTime       @map("due_at")
  status    DeadlineStatus
  riskLevel String         @map("risk_level")

  documentId String   @map("document_id")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_deadline")
}

model Notification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  title       String
  description String

  userId String @map("user_id")

  @@map("notifications")
}

enum ActionLogTypes {
  CREATE_TEAM
  UPDATE_TEAM

  ADD_USER
  INVITE_USER
  DELETE_USER
  DELETE_HIMSELF

  CREATE_DOCUMENT
  UPDATE_DOCUMENT
  DELETE_DOCUMENT
}

model ActionLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  type ActionLogTypes

  documentName String?
  documentId   String?   @map("document_id")
  document     Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  actorId        String  @map("actor_id")
  actorFullName  String  @map("actor_full_name")
  actorAvatarUrl String? @map("actor_avatar_url")

  userId        String? @map("user_id")
  userFullName  String? @map("user_full_name")
  userAvatarUrl String? @map("user_avatar_url")

  @@index([actorId])
  @@map("action_logs")
}
