generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

generator dbml {
  provider            = "prisma-dbml-generator"
  output              = "../dbml"
  outputName          = "schema.dbml"
  projectName         = "Expiry Team"
  projectDatabaseType = "PostgreSQL"
  projectNote         = "ER Diagram"
}

datasource db {
  provider = "postgresql"
}

// Document lifecycle statuses.
// PROCESSING   — files uploaded, analysis in progress
// ACTIVE       — document analyzed and valid
// NEEDS_REVIEW — low confidence or conflicting data detected
// FAILED       — processing error
// ARCHIVED     — manually archived by user

enum DocumentStatuses {
  PROCESSING
  ACTIVE
  ARCHIVED
  FAILED
  NEEDS_REVIEW
}

enum RiskLevels {
  LOW
  MEDIUM
  HIGH
}

model Document {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  status    DocumentStatuses
  name      String           @unique
  expiresAt DateTime?        @map("expires_at")
  riskLevel RiskLevels?      @map("risk_level")

  documentExtractedFields DocumentExtractedField[]
  actionLogs              ActionLog[]
  files                   File[]
  documentTags            DocumentTag[]

  @@map("documents")
}

model DocumentTag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  documentId String   @map("document_id") @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  tagId String @map("tag_id") @db.Uuid
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("document_tags")
}

model Tag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  tag String @unique

  documentTags DocumentTag[]

  @@map("tags")
}

model File {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  key          String   @unique
  fileSize     Float    @map("file_size")
  mimeType     String   @map("mime_type")
  url          String
  urlExpiresAt DateTime @map("url_expires_at")
  width        Float?
  height       Float?

  documentId String   @map("document_id") @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("files")
}

enum ExtractedFieldTypes {
  EXPIRY_DATE
  ISSUE_DATE
  COUNTERPARTY
  AMOUNT
}

enum ExtractedFieldSources {
  OCR
  REGEX
  MANUAL
}

model DocumentExtractedField {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  type       ExtractedFieldTypes
  value      String
  // TODO add in migration Confidence score in range [0.0 - 1.0]
  confidence Float
  source     ExtractedFieldSources

  documentId String   @map("document_id") @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_extracted_fields")
}

enum ActionLogTypes {
  CREATE_TEAM
  UPDATE_TEAM

  ADD_USER
  INVITE_USER
  DELETE_USER
  DELETE_HIMSELF

  CREATE_DOCUMENT
  UPDATE_DOCUMENT
  DELETE_DOCUMENT
}

model ActionLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  type ActionLogTypes

  documentName String?
  documentId   String?   @map("document_id") @db.Uuid
  document     Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  actorId        String  @map("actor_id") @db.Uuid
  actorFullName  String  @map("actor_full_name")
  actorAvatarUrl String? @map("actor_avatar_url")

  userId        String? @map("user_id") @db.Uuid
  userFullName  String? @map("user_full_name")
  userAvatarUrl String? @map("user_avatar_url")

  @@index([actorId])
  @@map("action_logs")
}

model Chat {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  name String @unique

  messages ChatMessage[]
  members  ChatMember[]

  @@map("chats")
}

enum ChatMemberStatus {
  ACTIVE
  DELETED
}

model ChatMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  status ChatMemberStatus

  userId        String  @map("user_id") @db.Uuid
  userFullName  String  @map("user_full_name")
  userAvatarUrl String? @map("user_avatar_url")

  chatId String @map("chat_id") @db.Uuid
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  messages                ChatMessage[]
  chatMessageReadStatuses ChatMessageReadStatus[]

  @@unique([chatId, userId])
  @@map("chat_members")
}

model ChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  message String

  parentMessageId String      @map("parent_message_id") @db.Uuid
  parentMessage   ChatMessage @relation("ThreadRelation", fields: [parentMessageId], references: [id], onDelete: Restrict)

  authorId String     @map("author_id") @db.Uuid
  author   ChatMember @relation(fields: [authorId], references: [id], onDelete: Restrict)

  chatId String @map("chat_id") @db.Uuid
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  childMessages           ChatMessage[]           @relation("ThreadRelation")
  chatMessageReadStatuses ChatMessageReadStatus[]

  @@map("chat_messages")
}

model ChatMessageReadStatus {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  chatMessageId String      @map("chat_message_id") @db.Uuid
  chatMessage   ChatMessage @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)

  readById String     @map("read_by_id") @db.Uuid
  readBy   ChatMember @relation(fields: [readById], references: [id], onDelete: Cascade)

  @@unique([chatMessageId, readById])
  @@map("Chat_message_read_statuses")
}
