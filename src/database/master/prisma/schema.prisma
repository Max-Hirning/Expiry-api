generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

generator dbml {
  provider            = "prisma-dbml-generator"
  output              = "../dbml"
  outputName          = "schema.dbml"
  projectName         = "Expiry"
  projectDatabaseType = "PostgreSQL"
  projectNote         = "ER Diagram"
}

datasource db {
  provider = "postgresql"
}

enum UserRoles {
  SUPER_ADMIN
  SUB_ADMIN
  USER
}

enum UserStatuses {
  ACTIVE
  DEACTIVATED
  INVITED
}

enum MfaTypes {
  CUSTOM
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  fullName    String       @map("full_name")
  email       String       @unique
  phoneNumber String       @unique @map("phone_number")
  mfaType     MfaTypes?
  password    String
  lastLoginAt DateTime?    @map("last_login_at")
  invitedAt   DateTime?    @map("invited_at")
  role        UserRoles
  status      UserStatuses

  teamMembers             TeamMember[]
  refreshToken            RefreshToken?
  avatar                  Avatar?
  notifications           Notification[]
  notificationPreferences NotificationPreference?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  token     String   @unique
  expiresAt DateTime

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Avatar {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  key       String   @unique
  fileSize  Float    @map("file_size")
  mimeType  String   @map("mime_type")
  url       String
  expiredAt DateTime @map("expired_at")
  width     Float
  height    Float

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("avatars")
}

model NotificationPreference {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  teamNews           Boolean @map("team_news")
  documentNews       Boolean @map("document_news")
  inAppNotifications Boolean @map("in_app_notifications")
  emailNotifications Boolean @map("email_notifications")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Team {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  name String @unique

  logo          Logo?
  stats         TeamStat?
  notifications Notification[]
  teamMembers   TeamMember[]

  @@map("teams")
}

model TeamStat {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  totalDocuments Int @map("total_documents")

  /// Documents by status
  processingDocuments  Int @map("processing_documents")
  activeDocuments      Int @map("active_documents")
  archivedDocuments    Int @map("archived_documents")
  failedDocuments      Int @map("failed_documents")
  needsReviewDocuments Int @map("needs_review_documents")

  /// Risk-related metrics
  highRiskDocuments   Int @map("high_risk_documents")
  mediumRiskDocuments Int @map("medium_risk_documents")
  lowRiskDocuments    Int @map("low_risk_documents")

  /// Documents expiring soon (e.g. next 7 days)
  expiringSoonDocuments Int @map("expiring_soon_documents")

  teamId String @unique @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_stats")
}

enum TeamMemberRoles {
  ADMIN
  STAFF
}

model TeamMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  role TeamMemberRoles

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

model Logo {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  key       String   @unique
  fileSize  Float    @map("file_size")
  mimeType  String   @map("mime_type")
  url       String
  expiredAt DateTime @map("expired_at")
  width     Float
  height    Float

  teamId String @unique @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("logos")
}

enum NotificationTypes {
  INVITE_USER_IN_TEAM
  DELETE_USER_FROM_TEAM

  DELETE_DOCUMENT

  DELETE_TEAM
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  type   NotificationTypes
  readAt DateTime?         @map("read_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  teamName String?
  teamId   String? @map("team_id")
  team     Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  documentName String?
  documentId   String? @map("document_id")

  @@map("notifications")
}
